rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /usernames/{username} {
      allow read: if true; // kayıt ekranında oturum açılmadan önce kontrol gerekiyor
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid
                    && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    match /favoriler/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /urunler/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /markalar/{marka}/marka_urunleri/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // collectionGroup('marka_urunleri') sorguları için zorunlu wildcard kuralı
    match /{path=**}/marka_urunleri/{productId} {
      allow read: if true;
    }

    match /mekanlar/{venueId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
